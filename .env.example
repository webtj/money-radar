# Money Radar — Environment Configuration
# Copy this file to feeds.fun/.env and edit before starting.

# ===== General =====
FFUN_ENVIRONMENT=prod
FFUN_ENABLE_API_SPA=True
FFUN_ENABLE_API_ROOT=True

# ===== PostgreSQL =====
FFUN_POSTGRESQL__HOST=postgresql
FFUN_POSTGRESQL__USER=root
FFUN_POSTGRESQL__PASSWORD=change-me-to-a-strong-password
FFUN_POSTGRESQL__DATABASE=ffun

# ===== Security =====
FFUN_USER_SETTINGS_SECRET_KEY=change-me-to-a-random-string

# ===== Single User Mode =====
FFUN_AUTH_FORCE_EXTERNAL_USER_ID=dev-user
FFUN_AUTH_FORCE_EXTERNAL_IDENTITY_PROVIDER_ID=single_user

# ===== LLM — DeepSeek =====
FFUN_OPENAI_API_ENTRY_POINT=https://api.deepseek.com/v1
FFUN_OPENAI_API_KEY=sk-your-deepseek-api-key-here

# ===== Tag Processors Config =====
FFUN_LIBRARIAN_TAG_PROCESSORS_CONFIG=.configs/tag_processors.toml

# ===== Domain (if you have one) =====
# FFUN_APP_DOMAIN=your.domain.com

# ===== License System =====
LICENSE_SECRET_KEY=change-me-to-a-random-string

# ===== Sentry (optional) =====
FFUN_ENABLE_SENTRY=False
